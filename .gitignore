# =============================================
# .gitignore — Raíz del proyecto
# =============================================

# Variables de entorno — nunca subir credenciales
.env
.env.*
!.env.example

# Dependencias
node_modules/

# Builds
dist/
build/
dist-ssr/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Sistema operativo
.DS_Store
Thumbs.db

# Editores
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.sw?

# Temporales
*.local
.temp/
.tmp/
screenshots/

# Instrucciones privadas para Claude Code
CLAUDE.md
