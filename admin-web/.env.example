# Configuración de la aplicación frontend
# Copiar este archivo a .env.local para desarrollo local

# API Base URL
# Desarrollo: http://localhost:3001
# Producción: https://api.tudominio.com
VITE_API_URL=http://localhost:3001

# Ambiente
# Valores: development, staging, production
VITE_ENVIRONMENT=development

# Logging
# Valores: debug, info, warn, error
VITE_LOG_LEVEL=info

# NUNCA agregues aquí:
# - API Keys
# - Contraseñas
# - Secretos
# - Tokens JWT
# Si necesitas estos, usa variables de entorno del servidor o backend
